[".local/share/zsh/zsh-autosuggestions"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = {{ .external.refreshPeriod | quote }}

[".local/share/zsh/zsh-syntax-highlighting"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-syntax-highlighting/archive/master.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = {{ .external.refreshPeriod | quote }}

[".config/nvim"]
    type = "git-repo"
    url = "https://github.com/jeromegamez/kickstart.nvim"
    exact = true
    stripComponents = 1
    refreshPeriod = {{ .external.refreshPeriod | quote }}



[".config/claude/commands"]
    type = "archive"
    url = "https://github.com/brennercruvinel/CCPlugins/archive/main.tar.gz"
    exact = false
    stripComponents = 2
    include = ["*/commands/*"]
    refreshPeriod = {{ .external.refreshPeriod | quote }}
