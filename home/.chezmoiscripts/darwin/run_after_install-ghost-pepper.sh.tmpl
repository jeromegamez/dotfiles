#!/usr/bin/env bash

set -eufo pipefail

APP_NAME="GhostPepper"
APP_PATH="/Applications/${APP_NAME}.app"
REPO="matthartman/ghost-pepper"
RELEASE_URL="https://github.com/${REPO}/releases/download"

get_latest_version() {
    curl -s "https://api.github.com/repos/${REPO}/releases/latest" | \
        grep -oE '"tag_name": "[^"]*"' | cut -d'"' -f4 | sed 's/^v//'
}

get_installed_version() {
    if [[ -d "$APP_PATH" ]]; then
        defaults read "${APP_PATH}/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    else
        echo ""
    fi
}

install_ghost_pepper() {
    local version="$1"
    local temp_dir
    temp_dir=$(mktemp -d)
    local dmg_path="${temp_dir}/${APP_NAME}.dmg"
    local mount_point="${temp_dir}/mount"

    echo "Installing ${APP_NAME} v${version}..."

    echo "Downloading ${APP_NAME}..."
    curl -L "${RELEASE_URL}/v${version}/${APP_NAME}.dmg" -o "$dmg_path"

    echo "Mounting DMG..."
    hdiutil attach "$dmg_path" -mountpoint "$mount_point" -nobrowse -quiet

    echo "Copying to /Applications..."
    rm -rf "$APP_PATH"
    cp -R "${mount_point}/${APP_NAME}.app" /Applications/

    echo "Unmounting DMG..."
    hdiutil detach "$mount_point" -quiet

    rm -rf "$temp_dir"

    echo "✓ ${APP_NAME} v${version} installed successfully"
}

LATEST_VERSION=$(get_latest_version)
INSTALLED_VERSION=$(get_installed_version)

if [[ "$INSTALLED_VERSION" == "$LATEST_VERSION" ]]; then
    echo "✓ ${APP_NAME} is up to date (${INSTALLED_VERSION})"
else
    install_ghost_pepper "$LATEST_VERSION"
fi
