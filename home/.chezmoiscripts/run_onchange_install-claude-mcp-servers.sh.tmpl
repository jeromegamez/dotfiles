#!/bin/bash
# Register MCP servers with Claude Code
# Runs when this script changes (new servers, config updates)

set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
    exit 0
fi

# Get list of registered servers
registered=$(claude mcp list 2>/dev/null | tail -n +2 | awk -F: '{print $1}' || echo "")

# Function to add server if not exists
add_if_missing() {
    local name="$1"
    shift
    if echo "$registered" | grep -q "^${name}$"; then
        echo "⊘ MCP server '$name' already registered"
    else
        claude mcp add "$@" && echo "✔ MCP server '$name' registered"
    fi
}

# HTTP servers
add_if_missing context7 --transport http context7 https://mcp.context7.com/mcp --header "CONTEXT7_API_KEY: {{ .credentials.context7ApiKey }}"
add_if_missing aws-knowledge --transport http aws-knowledge https://knowledge-mcp.global.api.aws

# stdio servers
add_if_missing sequential-thinking --transport stdio sequential-thinking -- npx -y @modelcontextprotocol/server-sequential-thinking
add_if_missing terraform --transport stdio terraform -- docker run -i --rm hashicorp/terraform-mcp-server
add_if_missing terraform-aws --transport stdio terraform-aws --env FASTMCP_LOG_LEVEL=error -- uvx awslabs.terraform-mcp-server@latest
add_if_missing Homebrew --transport stdio Homebrew -- brew mcp-server
