{{- $workEmail := "jerome@elvah.de" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    onepasswordAccount = "UM5PFDCXWRDOXA2MBGNTMSFJ24"
{{- if eq .chezmoi.os "darwin" }}
    computername = "Kerngehäuse"
    hostname = "kerngehaeuse"
    homebrewPrefix = "/opt/homebrew"
{{- end }}

[data.credentials]
    githubToken = {{ onepasswordRead "op://private/GitHub/Personal Access Tokens/Avoid Rate Limits" .onepasswordAccount | trim | quote }}
    githubComposerToken = {{ onepasswordRead "op://private/GitHub/Personal Access Tokens/Composer" .onepasswordAccount | trim | quote }}
    gitlabToken = {{ onepasswordRead "op://private/Gitlab read_api token/credential" .onepasswordAccount | trim | quote }}
    awsConfig = {{ onepasswordRead "op://private/awscli/notesPlain" .onepasswordAccount | trim | quote }}
    sshConfig = {{ onepasswordRead "op://private/SSH Config/notesPlain" .onepasswordAccount | trim | quote }}
    context7ApiKey = {{ onepasswordRead "op://private/Context7/API Key" .onepasswordAccount | trim | quote }}

[data.git]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    signingKey = "4E902530D3BC24D1"

[data.git.work]
    email = {{ $workEmail | quote }}
    directory = "~/Code/elvah/"

[data.versions]
    googleCloudSdk = "464.0.0"
    php = "8.4"

[data.macos]
    timezone = "Europe/Berlin"

[data.external]
    refreshPeriod = "168h"

